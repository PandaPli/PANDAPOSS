generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id         String     @id @default(uuid())
  nombre     String     @db.VarChar(100)
  plan       PlanTipo   @default(BASICO)
  creadoEn   DateTime   @default(now())
  clientes   Cliente[]
  pedidos    Pedido[]
  productos  Producto[]
  sucursales Sucursal[]
  usuarios   Usuario[]

  @@map("tenants")
}

model Sucursal {
  id            Int            @id @default(autoincrement())
  nombre        String         @db.VarChar(100)
  direccion     String?        @db.VarChar(200)
  telefono      String?        @db.VarChar(20)
  email         String?        @db.VarChar(100)
  simbolo       String         @default("$") @db.VarChar(5)
  activa        Boolean        @default(true)
  plan          PlanTipo       @default(BASICO)
  delivery      Boolean        @default(false)
  menuQR        Boolean        @default(false)
  correoActivo  Boolean        @default(false)
  creadoEn      DateTime       @default(now())
  logoUrl       String?        @db.VarChar(255)
  orden         Int            @default(0)
  tenantId      String?
  printerPath   String?        @default("/dev/usb/lp0") @db.VarChar(50)
  rut           String?        @db.VarChar(30)
  giroComercial String?        @db.VarChar(200)
  zonasDelivery Json?
  asistencias   Asistencia[]
  cajas         Caja[]
  clientes      Cliente[]
  departamentos Departamento[]
  empleados     Empleado[]
  ingredientes  Ingrediente[]
  permisosRrhh  PermisoRrhh[]
  productos     Producto[]
  salas         Sala[]
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  turnos        Turno[]
  usuarios      Usuario[]
  vacaciones    Vacacion[]

  @@index([tenantId], map: "sucursales_tenantId_fkey")
  @@map("sucursales")
}

model Usuario {
  id                Int              @id @default(autoincrement())
  nombre            String           @db.VarChar(100)
  usuario           String           @unique @db.VarChar(50)
  password          String           @db.VarChar(255)
  email             String?          @db.VarChar(100)
  rol               Rol              @default(WAITER)
  status            EstadoUsuario    @default(ACTIVO)
  sucursalId        Int?
  creadoEn          DateTime         @default(now())
  actualizadoEn     DateTime         @updatedAt
  tenantId          String?
  arqueos           Arqueo[]
  cajas             Caja[]
  empleadoRrhh      Empleado?
  logs              Log[]
  movimientosCaja   MovimientoCaja[]
  pedidosRepartidor Pedido[]         @relation("PedidosRepartidor")
  pedidos           Pedido[]
  repartidor        Repartidor?
  sucursal          Sucursal?        @relation(fields: [sucursalId], references: [id])
  tenant            Tenant?          @relation(fields: [tenantId], references: [id])
  ventas            Venta[]

  @@index([sucursalId], map: "usuarios_sucursalId_fkey")
  @@index([tenantId], map: "usuarios_tenantId_fkey")
  @@map("usuarios")
}

model Sala {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(80)
  sucursalId Int
  activa     Boolean  @default(true)
  creadoEn   DateTime @default(now())
  esQR       Boolean  @default(false)
  mesas      Mesa[]
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])

  @@index([sucursalId], map: "salas_sucursalId_fkey")
  @@map("salas")
}

model Mesa {
  id        Int        @id @default(autoincrement())
  nombre    String     @db.VarChar(50)
  capacidad Int        @default(4)
  estado    EstadoMesa @default(LIBRE)
  salaId    Int
  creadoEn  DateTime   @default(now())
  sala      Sala       @relation(fields: [salaId], references: [id])
  pedidos   Pedido[]

  @@index([salaId], map: "mesas_salaId_fkey")
  @@map("mesas")
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique @db.VarChar(80)
  icono     String?    @db.VarChar(50)
  activa    Boolean    @default(true)
  estacion  Estacion   @default(COCINA)
  orden     Int        @default(0)
  combos    Combo[]
  productos Producto[]

  @@map("categorias")
}

model Producto {
  id             Int             @id @default(autoincrement())
  codigo         String          @unique @db.VarChar(30)
  nombre         String          @db.VarChar(120)
  descripcion    String?         @db.Text
  precio         Decimal         @db.Decimal(10, 2)
  costo          Decimal?        @db.Decimal(10, 2)
  stock          Decimal         @default(0.00) @db.Decimal(10, 2)
  stockMinimo    Decimal         @default(0.00) @db.Decimal(10, 2)
  imagen         String?         @db.VarChar(255)
  ivaActivo      Boolean         @default(false)
  ivaPorc        Decimal         @default(0.00) @db.Decimal(5, 2)
  activo         Boolean         @default(true)
  enMenu         Boolean         @default(true)
  categoriaId    Int?
  sucursalId     Int?
  creadoEn       DateTime        @default(now())
  actualizadoEn  DateTime        @updatedAt
  tenantId       String?
  enMenuQR       Boolean         @default(true)
  detallesPedido DetallePedido[]
  detallesVenta  DetalleVenta[]
  kardex         Kardex[]
  categoria      Categoria?      @relation(fields: [categoriaId], references: [id])
  sucursal       Sucursal?       @relation(fields: [sucursalId], references: [id])
  Tenant         Tenant?         @relation(fields: [tenantId], references: [id])

  @@index([categoriaId], map: "productos_categoriaId_fkey")
  @@index([sucursalId], map: "productos_sucursalId_fkey")
  @@index([tenantId], map: "productos_tenantId_fkey")
  @@map("productos")
}

model Ingrediente {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique @db.VarChar(30)
  nombre      String    @db.VarChar(120)
  stock       Decimal   @default(0.00) @db.Decimal(10, 2)
  stockMinimo Decimal   @default(0.00) @db.Decimal(10, 2)
  unidad      String    @default("und") @db.VarChar(20)
  costo       Decimal?  @db.Decimal(10, 2)
  sucursalId  Int?
  activo      Boolean   @default(true)
  creadoEn    DateTime  @default(now())
  sucursal    Sucursal? @relation(fields: [sucursalId], references: [id])

  @@index([sucursalId], map: "ingredientes_sucursalId_fkey")
  @@map("ingredientes")
}

model Combo {
  id             Int             @id @default(autoincrement())
  codigo         String          @unique @db.VarChar(30)
  nombre         String          @db.VarChar(120)
  precio         Decimal         @db.Decimal(10, 2)
  imagen         String?         @db.VarChar(255)
  categoriaId    Int?
  activo         Boolean         @default(true)
  enMenu         Boolean         @default(true)
  creadoEn       DateTime        @default(now())
  categoria      Categoria?      @relation(fields: [categoriaId], references: [id])
  detallesPedido DetallePedido[]
  detallesVenta  DetalleVenta[]

  @@index([categoriaId], map: "combos_categoriaId_fkey")
  @@map("combos")
}

model Cliente {
  id              Int                @id @default(autoincrement())
  rut             String?            @unique @db.VarChar(20)
  nombre          String             @db.VarChar(120)
  email           String?            @db.VarChar(100)
  telefono        String?            @db.VarChar(20)
  direccion       String?            @db.VarChar(200)
  activo          Boolean            @default(true)
  sucursalId      Int?
  creadoEn        DateTime           @default(now())
  tenantId        String?
  sucursal        Sucursal?          @relation(fields: [sucursalId], references: [id])
  Tenant          Tenant?            @relation(fields: [tenantId], references: [id])
  direcciones     DireccionCliente[]
  pedidosDelivery PedidoDelivery[]
  ventas          Venta[]

  @@index([sucursalId], map: "clientes_sucursalId_fkey")
  @@index([tenantId], map: "clientes_tenantId_fkey")
  @@map("clientes")
}

model Proveedor {
  id       Int      @id @default(autoincrement())
  rut      String?  @unique @db.VarChar(20)
  nombre   String   @db.VarChar(120)
  email    String?  @db.VarChar(100)
  telefono String?  @db.VarChar(20)
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now())

  @@map("proveedores")
}

model Caja {
  id          Int              @id @default(autoincrement())
  nombre      String           @db.VarChar(80)
  estado      EstadoCaja       @default(CERRADA)
  saldoInicio Decimal          @default(0.00) @db.Decimal(10, 2)
  sucursalId  Int
  usuarioId   Int?
  abiertaEn   DateTime?
  cerradaEn   DateTime?
  creadoEn    DateTime         @default(now())
  arqueos     Arqueo[]
  sucursal    Sucursal         @relation(fields: [sucursalId], references: [id])
  usuario     Usuario?         @relation(fields: [usuarioId], references: [id])
  movimientos MovimientoCaja[]
  pedidos     Pedido[]
  ventas      Venta[]

  @@index([sucursalId], map: "cajas_sucursalId_fkey")
  @@index([usuarioId], map: "cajas_usuarioId_fkey")
  @@map("cajas")
}

model MovimientoCaja {
  id        Int                @id @default(autoincrement())
  tipo      TipoMovimientoCaja
  monto     Decimal            @db.Decimal(10, 2)
  motivo    String             @db.VarChar(200)
  cajaId    Int
  usuarioId Int
  creadoEn  DateTime           @default(now())
  caja      Caja               @relation(fields: [cajaId], references: [id])
  usuario   Usuario            @relation(fields: [usuarioId], references: [id])

  @@index([cajaId], map: "movimientos_caja_cajaId_fkey")
  @@index([usuarioId], map: "movimientos_caja_usuarioId_fkey")
  @@map("movimientos_caja")
}

model Arqueo {
  id          Int       @id @default(autoincrement())
  cajaId      Int
  usuarioId   Int
  saldoInicio Decimal   @db.Decimal(10, 2)
  saldoFinal  Decimal?  @db.Decimal(10, 2)
  totalVentas Decimal?  @db.Decimal(10, 2)
  diferencia  Decimal?  @db.Decimal(10, 2)
  observacion String?   @db.Text
  abiertaEn   DateTime  @default(now())
  cerradaEn   DateTime?
  caja        Caja      @relation(fields: [cajaId], references: [id])
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])

  @@index([cajaId], map: "arqueos_cajaId_fkey")
  @@index([usuarioId], map: "arqueos_usuarioId_fkey")
  @@map("arqueos")
}

model Pedido {
  id               Int             @id @default(autoincrement())
  numero           Int             @default(0)
  mesaId           Int?
  cajaId           Int?
  usuarioId        Int
  repartidorId     Int?
  tipo             TipoPedido      @default(COCINA)
  estado           EstadoPedido    @default(PENDIENTE)
  observacion      String?         @db.Text
  meseroLlamado    Boolean         @default(false)
  direccionEntrega String?         @db.VarChar(300)
  telefonoCliente  String?         @db.VarChar(30)
  creadoEn         DateTime        @default(now())
  actualizadoEn    DateTime        @updatedAt
  tenantId         String?
  detalles         DetallePedido[]
  caja             Caja?           @relation(fields: [cajaId], references: [id])
  mesa             Mesa?           @relation(fields: [mesaId], references: [id])
  repartidor       Usuario?        @relation("PedidosRepartidor", fields: [repartidorId], references: [id])
  Tenant           Tenant?         @relation(fields: [tenantId], references: [id])
  usuario          Usuario         @relation(fields: [usuarioId], references: [id])
  delivery         PedidoDelivery?
  venta            Venta?

  @@index([cajaId], map: "pedidos_cajaId_fkey")
  @@index([mesaId], map: "pedidos_mesaId_fkey")
  @@index([repartidorId], map: "pedidos_repartidorId_fkey")
  @@index([tenantId], map: "pedidos_tenantId_fkey")
  @@index([usuarioId], map: "pedidos_usuarioId_fkey")
  @@map("pedidos")
}

model DetallePedido {
  id          Int       @id @default(autoincrement())
  pedidoId    Int
  productoId  Int?
  comboId     Int?
  cantidad    Int       @default(1)
  observacion String?   @db.VarChar(200)
  cancelado   Boolean   @default(false)
  grupo       String?   @db.VarChar(5)
  pagado      Boolean   @default(false)
  precio      Decimal?  @db.Decimal(10, 2)
  combo       Combo?    @relation(fields: [comboId], references: [id])
  pedido      Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto    Producto? @relation(fields: [productoId], references: [id])

  @@index([comboId], map: "detalles_pedidos_comboId_fkey")
  @@index([pedidoId], map: "detalles_pedidos_pedidoId_fkey")
  @@index([productoId], map: "detalles_pedidos_productoId_fkey")
  @@map("detalles_pedidos")
}

model Venta {
  id          Int            @id @default(autoincrement())
  numero      String         @unique @db.VarChar(20)
  cajaId      Int?
  clienteId   Int?
  usuarioId   Int
  pedidoId    Int?           @unique
  subtotal    Decimal        @db.Decimal(10, 2)
  descuento   Decimal        @default(0.00) @db.Decimal(10, 2)
  impuesto    Decimal        @default(0.00) @db.Decimal(10, 2)
  total       Decimal        @db.Decimal(10, 2)
  metodoPago  MetodoPago     @default(EFECTIVO)
  estado      EstadoVenta    @default(PAGADA)
  observacion String?        @db.Text
  creadoEn    DateTime       @default(now())
  detalles    DetalleVenta[]
  kardex      Kardex[]
  pagos       PagoVenta[]
  caja        Caja?          @relation(fields: [cajaId], references: [id])
  cliente     Cliente?       @relation(fields: [clienteId], references: [id])
  pedido      Pedido?        @relation(fields: [pedidoId], references: [id])
  usuario     Usuario        @relation(fields: [usuarioId], references: [id])

  @@index([cajaId], map: "ventas_cajaId_fkey")
  @@index([clienteId], map: "ventas_clienteId_fkey")
  @@index([usuarioId], map: "ventas_usuarioId_fkey")
  @@map("ventas")
}

model DetalleVenta {
  id         Int       @id @default(autoincrement())
  ventaId    Int
  productoId Int?
  comboId    Int?
  cantidad   Int       @default(1)
  precio     Decimal   @db.Decimal(10, 2)
  descuento  Decimal   @default(0.00) @db.Decimal(10, 2)
  subtotal   Decimal   @db.Decimal(10, 2)
  combo      Combo?    @relation(fields: [comboId], references: [id])
  producto   Producto? @relation(fields: [productoId], references: [id])
  venta      Venta     @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([comboId], map: "detalles_ventas_comboId_fkey")
  @@index([productoId], map: "detalles_ventas_productoId_fkey")
  @@index([ventaId], map: "detalles_ventas_ventaId_fkey")
  @@map("detalles_ventas")
}

model Kardex {
  id         Int        @id @default(autoincrement())
  productoId Int
  tipo       TipoKardex
  cantidad   Decimal    @db.Decimal(10, 2)
  motivo     String     @db.VarChar(100)
  ventaId    Int?
  creadoEn   DateTime   @default(now())
  producto   Producto   @relation(fields: [productoId], references: [id])
  venta      Venta?     @relation(fields: [ventaId], references: [id])

  @@index([productoId], map: "kardex_productoId_fkey")
  @@index([ventaId], map: "kardex_ventaId_fkey")
  @@map("kardex")
}

model PagoVenta {
  id         Int        @id @default(autoincrement())
  ventaId    Int
  metodoPago MetodoPago
  monto      Decimal    @db.Decimal(10, 2)
  referencia String?    @db.VarChar(100)
  creadoEn   DateTime   @default(now())
  venta      Venta      @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([ventaId], map: "pagos_ventas_ventaId_fkey")
  @@map("pagos_ventas")
}

model Log {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  accion    String   @db.VarChar(200)
  ip        String?  @db.VarChar(50)
  creadoEn  DateTime @default(now())
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId], map: "logs_usuarioId_fkey")
  @@map("logs")
}

model Configuracion {
  id            Int     @id @default(1)
  nombreEmpresa String  @default("PandaPoss") @db.VarChar(100)
  rut           String? @db.VarChar(20)
  direccion     String? @db.VarChar(200)
  telefono      String? @db.VarChar(20)
  email         String? @db.VarChar(100)
  logoUrl       String? @db.VarChar(255)
  moneda        String  @default("CLP") @db.VarChar(10)
  simbolo       String  @default("$") @db.VarChar(5)
  ivaPorc       Decimal @default(19.00) @db.Decimal(5, 2)

  @@map("configuracion")
}

model Departamento {
  id            Int        @id @default(autoincrement())
  sucursalId    Int
  nombre        String     @db.VarChar(100)
  descripcion   String?    @db.VarChar(255)
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  sucursal      Sucursal   @relation(fields: [sucursalId], references: [id])
  empleados     Empleado[]

  @@unique([sucursalId, nombre])
  @@map("departamentos")
}

model Cargo {
  id            Int        @id @default(autoincrement())
  nombre        String     @unique @db.VarChar(100)
  descripcion   String?    @db.VarChar(255)
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  empleados     Empleado[]

  @@map("cargos")
}

model Empleado {
  id             Int           @id @default(autoincrement())
  sucursalId     Int
  usuarioId      Int?          @unique
  departamentoId Int?
  cargoId        Int?
  nombres        String        @db.VarChar(100)
  apellidos      String        @db.VarChar(100)
  documento      String?       @unique @db.VarChar(30)
  email          String?       @unique @db.VarChar(100)
  telefono       String?       @db.VarChar(20)
  fechaIngreso   DateTime?
  salarioBase    Decimal?      @db.Decimal(10, 2)
  activo         Boolean       @default(true)
  creadoEn       DateTime      @default(now())
  actualizadoEn  DateTime      @updatedAt
  asistencias    Asistencia[]
  cargo          Cargo?        @relation(fields: [cargoId], references: [id])
  departamento   Departamento? @relation(fields: [departamentoId], references: [id])
  sucursal       Sucursal      @relation(fields: [sucursalId], references: [id])
  usuario        Usuario?      @relation(fields: [usuarioId], references: [id])
  permisos       PermisoRrhh[]
  turnos         Turno[]
  vacaciones     Vacacion[]

  @@index([sucursalId])
  @@index([usuarioId])
  @@index([departamentoId])
  @@index([cargoId])
  @@map("empleados")
}

model Turno {
  id            Int       @id @default(autoincrement())
  sucursalId    Int
  empleadoId    Int?
  nombre        String    @db.VarChar(100)
  horaEntrada   String    @db.VarChar(10)
  horaSalida    String    @db.VarChar(10)
  diasSemana    String    @db.VarChar(80)
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  empleado      Empleado? @relation(fields: [empleadoId], references: [id])
  sucursal      Sucursal  @relation(fields: [sucursalId], references: [id])

  @@index([sucursalId])
  @@index([empleadoId])
  @@map("turnos")
}

model Asistencia {
  id            Int       @id @default(autoincrement())
  sucursalId    Int
  empleadoId    Int
  fecha         DateTime
  horaEntrada   DateTime?
  horaSalida    DateTime?
  estado        String    @db.VarChar(30)
  observacion   String?   @db.VarChar(255)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  empleado      Empleado  @relation(fields: [empleadoId], references: [id])
  sucursal      Sucursal  @relation(fields: [sucursalId], references: [id])

  @@unique([empleadoId, fecha])
  @@index([sucursalId])
  @@index([empleadoId])
  @@map("asistencias")
}

model PermisoRrhh {
  id            Int      @id @default(autoincrement())
  sucursalId    Int
  empleadoId    Int
  tipo          String   @db.VarChar(50)
  fechaInicio   DateTime
  fechaFin      DateTime
  motivo        String?  @db.VarChar(255)
  estado        String   @default("PENDIENTE") @db.VarChar(30)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  empleado      Empleado @relation(fields: [empleadoId], references: [id])
  sucursal      Sucursal @relation(fields: [sucursalId], references: [id])

  @@index([sucursalId])
  @@index([empleadoId])
  @@map("permisos_rrhh")
}

model Vacacion {
  id            Int      @id @default(autoincrement())
  sucursalId    Int
  empleadoId    Int
  fechaInicio   DateTime
  fechaFin      DateTime
  dias          Int
  estado        String   @default("PENDIENTE") @db.VarChar(30)
  observacion   String?  @db.VarChar(255)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  empleado      Empleado @relation(fields: [empleadoId], references: [id])
  sucursal      Sucursal @relation(fields: [sucursalId], references: [id])

  @@index([sucursalId])
  @@index([empleadoId])
  @@map("vacaciones")
}

model PedidoDelivery {
  id             Int              @id @default(autoincrement())
  pedidoId       Int              @unique
  clienteId      Int
  repartidorId   Int?
  direccionId    Int
  referencia     String?          @db.VarChar(200)
  lat            Float
  lng            Float
  costoEnvio     Decimal          @db.Decimal(10, 2)
  zonaDelivery   String?          @db.VarChar(100)
  tiempoEstimado Int
  estado         EstadoDelivery   @default(CREADO)
  creadoEn       DateTime         @default(now())
  eventos        EventoDelivery[]
  cliente        Cliente          @relation(fields: [clienteId], references: [id])
  direccion      DireccionCliente @relation(fields: [direccionId], references: [id])
  pedido         Pedido           @relation(fields: [pedidoId], references: [id])
  repartidor     Repartidor?      @relation(fields: [repartidorId], references: [id])

  @@index([clienteId], map: "pedidos_delivery_clienteId_fkey")
  @@index([direccionId], map: "pedidos_delivery_direccionId_fkey")
  @@index([repartidorId], map: "pedidos_delivery_repartidorId_fkey")
  @@map("pedidos_delivery")
}

model DireccionCliente {
  id         Int              @id @default(autoincrement())
  clienteId  Int
  calle      String           @db.VarChar(200)
  numero     String?          @db.VarChar(50)
  referencia String?          @db.VarChar(200)
  lat        Float
  lng        Float
  cliente    Cliente          @relation(fields: [clienteId], references: [id])
  pedidos    PedidoDelivery[]

  @@index([clienteId], map: "direcciones_cliente_clienteId_fkey")
  @@map("direcciones_cliente")
}

model Repartidor {
  id             Int              @id @default(autoincrement())
  usuarioId      Int              @unique
  vehiculo       String           @db.VarChar(100)
  estado         EstadoRepartidor @default(INACTIVO)
  lat            Float?
  lng            Float?
  pedidosActivos Int              @default(0)
  entregas       PedidoDelivery[]
  usuario        Usuario          @relation(fields: [usuarioId], references: [id])

  @@map("repartidores")
}

model EventoDelivery {
  id               Int            @id @default(autoincrement())
  pedidoDeliveryId Int
  estado           EstadoDelivery
  creadoEn         DateTime       @default(now())
  delivery         PedidoDelivery @relation(fields: [pedidoDeliveryId], references: [id])

  @@index([pedidoDeliveryId], map: "eventos_delivery_pedidoDeliveryId_fkey")
  @@map("eventos_delivery")
}

