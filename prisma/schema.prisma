model Cupon {
  id          Int       @id @default(autoincrement())
  sucursalId  Int
  codigo      String    @db.VarChar(50)
  descripcion String?   @db.VarChar(200)
  tipo        TipoCupon
  valor       Decimal   @db.Decimal(10, 2)
  usoMax      Int?
  usoActual   Int       @default(0)
  activo      Boolean   @default(true)
  venceEn     DateTime?
  creadoEn    DateTime  @default(now())
  sucursal    Sucursal  @relation(fields: [sucursalId], references: [id])
  ventas      Venta[]

  @@unique([sucursalId, codigo])
  @@index([sucursalId], map: "cupones_sucursalId_fkey")
  @@map("cupones")
}

model Evento {
  id          Int            @id @default(autoincrement())
  nombre      String         @db.VarChar(150)
  descripcion String?        @db.Text
  fecha       DateTime
  lugar       String?        @db.VarChar(200)
  precio      Decimal        @db.Decimal(10, 2)
  capacidad   Int            @default(0)
  imagenUrl   String?        @db.VarChar(500)
  activo      Boolean        @default(true)
  sucursalId  Int
  tenantId    String
  creadoEn    DateTime       @default(now())
  sucursal    Sucursal       @relation(fields: [sucursalId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  tickets     TicketEvento[]

  @@map("eventos")
}

model TicketEvento {
  id               Int          @id @default(autoincrement())
  token            String       @unique @db.VarChar(600)
  eventoId         Int
  clienteId        Int?
  clienteNombre    String       @db.VarChar(150)
  clienteEmail     String       @db.VarChar(150)
  clienteTelefono  String?      @db.VarChar(20)
  metodoPago       MetodoPago   @default(EFECTIVO)
  estado           EstadoTicket @default(PENDIENTE_PAGO)
  usosMax          Int          @default(1)
  usosRealizados   Int          @default(0)
  monto            Decimal      @db.Decimal(10, 2)
  referenciaPago   String?      @db.VarChar(200)
  creadoEn         DateTime     @default(now())
  validadoEn       DateTime?
  evento           Evento       @relation(fields: [eventoId], references: [id])
  cliente          Cliente?     @relation(fields: [clienteId], references: [id])

  @@map("tickets_evento")
}

enum EstadoTicket {
  PENDIENTE_PAGO
  PAGADO
  VALIDADO
  EXPIRADO
}

// ─── AGENTE WHATSAPP ────────────────────────────────────────────────

enum EstadoAgente {
  DESCONECTADO
  ESPERANDO_QR
  CONECTADO
  ERROR
}

model AgenteWsp {
  id          Int          @id @default(autoincrement())
  sucursalId  Int          @unique
  activo      Boolean      @default(false)
  estado      EstadoAgente @default(DESCONECTADO)
  telefono    String?      @db.VarChar(30)
  qrBase64    String?      @db.Text
  qrExpiresAt DateTime?
  ultimaConex DateTime?
  creadoEn    DateTime     @default(now())

  sucursal     Sucursal          @relation(fields: [sucursalId], references: [id])
  clientes     AgenteCliente[]
  eventos      AgenteEvento[]

  @@map("agentes_wsp")
}

model AgenteCliente {
  id         Int      @id @default(autoincrement())
  agenteId   Int
  telefono   String   @db.VarChar(30)
  nombre     String?  @db.VarChar(100)
  totalPedidos Int    @default(0)
  ultimoPedido DateTime?
  creadoEn   DateTime @default(now())

  agente       AgenteWsp            @relation(fields: [agenteId], references: [id])
  direcciones  AgenteDireccion[]
  preferencias AgentePreferencia[]
  sesiones     AgenteSesion[]

  @@unique([agenteId, telefono])
  @@map("agentes_clientes")
}

model AgenteDireccion {
  id        Int    @id @default(autoincrement())
  clienteId Int
  direccion String @db.VarChar(300)
  referencia String? @db.VarChar(200)
  usosCount Int    @default(1)

  cliente AgenteCliente @relation(fields: [clienteId], references: [id])

  @@map("agentes_direcciones")
}

model AgentePreferencia {
  id        Int    @id @default(autoincrement())
  clienteId Int
  texto     String @db.VarChar(300)
  creadoEn  DateTime @default(now())

  cliente AgenteCliente @relation(fields: [clienteId], references: [id])

  @@map("agentes_preferencias")
}

model AgenteEvento {
  id       Int      @id @default(autoincrement())
  agenteId Int
  tipo     String   @db.VarChar(50)
  payload  Json?
  creadoEn DateTime @default(now())

  agente AgenteWsp @relation(fields: [agenteId], references: [id])

  @@map("agentes_eventos")
}

model AgenteSesion {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  estado        String?
  carritoJson   Json?
  contextoJson  Json?
  historialJson Json?
  updatedAt     DateTime @default(now()) @updatedAt

  cliente AgenteCliente @relation(fields: [clienteId], references: [id])

  @@unique([clienteId])
  @@map("agentes_sesiones")
}

