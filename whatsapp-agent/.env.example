# URL del servidor PandaPoss
PANDAPOSS_URL=https://pandaposs.com

# Clave compartida para API interna (debe coincidir con AGENTE_API_KEY en Vercel)
AGENTE_API_KEY=tu_clave_secreta_aqui

# Anthropic API Key para el LLM
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude a usar (recomendado: claude-haiku-4-5-20251001 para velocidad)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Intervalo en ms para verificar agentes activos en PandaPoss
POLL_INTERVAL_MS=30000
